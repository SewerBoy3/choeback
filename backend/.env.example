# =============================================
# VARIABLES DE ENTORNO - BACKEND (Koyeb)
# Copiar estas variables en el panel de Koyeb
# =============================================

# Puerto (Koyeb lo asigna automáticamente con PORT, no cambiar)
PORT=5000

# URL del frontend en Vercel (sin barra final)
# Ejemplo: https://regalo-choe.vercel.app
FRONTEND_URL=https://TU_APP.vercel.app

# Base de datos PostgreSQL (Neon - https://neon.tech)
# Formato: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/regalo_choe?sslmode=require

# JWT Secret para tokens de autenticación (generá uno largo y random)
JWT_SECRET=cambia_esto_por_un_string_secreto_largo_y_seguro

# Integración con Discord (Opcional)
DISCORD_WEBHOOK_URL=
DISCORD_BOT_URL=

# Integración con Telegram (Opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudinary (almacenamiento principal)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=
